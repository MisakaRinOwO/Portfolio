---
import SiteLayout from '../layouts/SiteLayout.astro';
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
const resumeHref = `${base}/resume/resume.pdf`;
---

<SiteLayout
  title="Resume | Peter Xie"
  description="Resume of Peter (Ruilin) Xie — Gameplay / Systems Engineer."
>
  <main class="mx-auto max-w-4xl px-6 py-16 sm:px-8 sm:py-20 lg:px-12 lg:py-24">

    <p class="font-display text-[13px] uppercase tracking-[0.22em] text-accent-blue">Resume</p>
    <h1 class="mt-4 font-display text-[2.4rem] font-bold leading-none text-white sm:text-5xl">
      Peter (Ruilin) Xie
    </h1>
    <p class="mt-4 text-[1.04rem] text-white/58">Gameplay / Systems Engineer</p>

    <!-- Download button -->
    <div class="mt-10 flex flex-wrap gap-4">
      <a
        href={resumeHref}
        download="resume.pdf"
        class="inline-flex min-h-[48px] items-center gap-3 bg-accent-blue px-8 font-display text-[12px] uppercase tracking-[0.2em] text-white transition-all duration-300 hover:bg-white hover:text-page-bg"
      >
        <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/>
          <polyline points="7 10 12 15 17 10"/>
          <line x1="12" y1="15" x2="12" y2="3"/>
        </svg>
        Download PDF
      </a>
      <a
        href={resumeHref}
        target="_blank"
        rel="noopener noreferrer"
        class="inline-flex min-h-[48px] items-center gap-3 border border-white/20 px-8 font-display text-[12px] uppercase tracking-[0.2em] text-white/60 transition-all duration-300 hover:border-accent-blue/40 hover:text-accent-blue"
      >
        Open in new tab
      </a>
    </div>

    <!-- PDF preview (hidden on small screens) -->
    <div class="mt-12 hidden border border-white/10 sm:block">
      <iframe
        src={resumeHref}
        title="Resume PDF preview"
        class="h-[80vh] w-full"
        aria-label="Resume PDF preview"
      ></iframe>
    </div>

    <p class="mt-6 text-sm text-white/36 sm:hidden">
      PDF preview is available on larger screens. Use the download button above.
    </p>

  </main>
</SiteLayout>
