---
import { getCollection, render } from 'astro:content';
import SiteLayout from '../../layouts/SiteLayout.astro';

export async function getStaticPaths() {
  const projects = await getCollection('projects');
  return projects.map((entry) => ({
    params: { slug: entry.id },
    props: { entry },
  }));
}

const base = import.meta.env.BASE_URL.replace(/\/$/, '');
const { entry } = Astro.props;
const { Content, headings } = await render(entry);
const d = entry.data;
const tocHeadings = headings.filter((h) => h.depth === 2);
---

<SiteLayout title={`${d.title} | Peter Xie`} description={d.summary}>
  <main class="mx-auto max-w-7xl px-6 py-16 sm:px-8 sm:py-20 lg:px-12 lg:py-24">

    <!-- Back link -->
    <a
      href={`${base}/projects/`}
      class="inline-flex items-center gap-3 font-display text-[13px] uppercase tracking-[0.2em] text-white/50 transition-colors duration-300 hover:text-accent-blue"
    >
      <span aria-hidden="true">←</span> All Projects
    </a>

    <!-- Under Construction banner -->
    {d.draft && (
      <div class="mt-6 flex items-start gap-4 border border-yellow-400/30 bg-yellow-400/[0.06] px-5 py-4">
        <svg class="mt-0.5 h-4 w-4 shrink-0 text-yellow-300" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true">
          <path stroke-linecap="round" stroke-linejoin="round" d="M12 9v3.75m-9.303 3.376c-.866 1.5.217 3.374 1.948 3.374h14.71c1.73 0 2.813-1.874 1.948-3.374L13.949 3.378c-.866-1.5-3.032-1.5-3.898 0L2.697 16.126zM12 15.75h.007v.008H12v-.008z" />
        </svg>
        <div>
          <p class="font-display text-[11px] uppercase tracking-[0.22em] text-yellow-300">Under Construction</p>
          <p class="mt-1 text-[0.9rem] leading-6 text-white/50">This write-up is still being completed. Content may be incomplete or placeholder.</p>
        </div>
      </div>
    )}

    <!-- ════════════════════════════════════════════════════════════════
         PART 1 — HERO
         Title · Summary · Project Info · Media
    ═══════════════════════════════════════════════════════════════════ -->
    <section class="mt-10" aria-label="Hero">

      <!-- Title + Sidebar -->
      <div class="grid gap-10 lg:grid-cols-[minmax(0,1fr)_280px] lg:items-start">
        <div>
          <!-- Tags -->
          {d.tags.length > 0 && (
            <div class="flex flex-wrap gap-2">
              {d.tags.map((tag) => (
                <span class="rounded-full border border-accent-blue/28 px-3 py-1 font-display text-[11px] uppercase tracking-[0.16em] text-accent-blue">
                  {tag}
                </span>
              ))}
            </div>
          )}
          <h1 class="mt-5 break-words font-display text-[2.6rem] font-bold leading-none text-white sm:text-5xl lg:text-6xl">
            {d.title}
          </h1>
          <p class="mt-6 max-w-3xl text-[1.1rem] leading-8 text-white/65">{d.summary}</p>
        </div>

        <!-- Meta sidebar -->
        <aside class="border border-white/10 bg-white/[0.03] p-6">
          <p class="font-display text-[12px] uppercase tracking-[0.2em] text-white/40">Project Info</p>
          <dl class="mt-5 space-y-5">
            <div>
              <dt class="font-display text-[11px] uppercase tracking-[0.18em] text-warm-gold">Year</dt>
              <dd class="mt-2 text-[1.02rem] text-white/72">{d.year}</dd>
            </div>
            <div>
              <dt class="font-display text-[11px] uppercase tracking-[0.18em] text-warm-gold">Role</dt>
              <dd class="mt-2 text-[1.02rem] text-white/72">{d.role}</dd>
            </div>
            <div>
              <dt class="font-display text-[11px] uppercase tracking-[0.18em] text-warm-gold">Stack</dt>
              <dd class="mt-2 text-[1.02rem] text-white/72">{d.stack}</dd>
            </div>
            {d.focus && (
              <div>
                <dt class="font-display text-[11px] uppercase tracking-[0.18em] text-warm-gold">Focus</dt>
                <dd class="mt-2 text-[1.02rem] text-white/72">{d.focus}</dd>
              </div>
            )}
          </dl>

          <!-- Links -->
          {d.links.demo && (
            <div class="mt-8 flex flex-col gap-3">
              <a
                href={d.links.demo}
                target="_blank"
                rel="noopener noreferrer"
                class="inline-flex min-h-10 items-center justify-center border border-white/20 px-5 font-display text-[12px] uppercase tracking-[0.18em] text-white/60 transition-colors duration-300 hover:border-accent-blue/40 hover:text-accent-blue"
              >
                Download / Play
              </a>
            </div>
          )}
        </aside>
      </div>

      <!-- Hero Media -->
      {(d.demoVideo || d.screenshots.length > 0) && (
        <div class="mt-10">
          {d.demoVideo ? (
            <div data-demo-video-block class="space-y-3">
              <div class="aspect-video w-full overflow-hidden border border-white/10 bg-black" data-demo-media>
                <iframe
                  src={`${d.demoVideo}${d.demoVideo.includes('?') ? '&' : '?'}enablejsapi=1&playsinline=1&rel=0`}
                  title={`${d.title} demo video`}
                  allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture"
                  allowfullscreen
                  class="h-full w-full"
                  data-demo-iframe
                ></iframe>
                {d.demoVideoFallback && (
                  <video
                    class="hidden h-full w-full"
                    controls
                    preload="metadata"
                    playsinline
                    data-demo-fallback
                  >
                    <source
                      src={d.demoVideoFallback.startsWith('/') ? `${base}${d.demoVideoFallback}` : d.demoVideoFallback}
                      type="video/mp4"
                    />
                    Your browser does not support the video tag.
                  </video>
                )}
              </div>
            </div>
          ) : (
            <div class={`grid gap-4 ${d.screenshots.length === 1 ? '' : 'sm:grid-cols-2'}`}>
              {d.screenshots.map((src, i) => (
                <img
                  src={src.startsWith('/') ? `${base}${src}` : src}
                  alt={`${d.title} screenshot ${i + 1}`}
                  class="w-full border border-white/8 object-cover"
                  loading="lazy"
                />
              ))}
            </div>
          )}
        </div>
      )}

    </section>

    <!-- ════════════════════════════════════════════════════════════════
         PARTS 2 + 3 — CONTENT + TOC
    ═══════════════════════════════════════════════════════════════════ -->
    <div class="mt-16 lg:grid lg:grid-cols-[minmax(0,1fr)_200px] lg:items-start lg:gap-10">

      <!-- TOC sidebar: fixed on mobile (always at top), sticky sidebar on desktop -->
      {tocHeadings.length > 0 && (
        <aside
          id="toc-aside"
          class="fixed left-0 right-0 z-40 bg-page-bg transition-transform duration-500 ease-[cubic-bezier(0.22,1,0.36,1)] will-change-transform lg:static lg:sticky lg:top-28 lg:order-last lg:mb-0"
          aria-label="Page contents"
        >
          <!-- Header / toggle button -->
          <button
            id="toc-toggle"
            class="flex w-full items-center justify-between border border-white/10 bg-white/[0.02] px-4 py-3 text-left transition-colors hover:border-accent-blue/30"
            aria-expanded="true"
            aria-controls="toc-list"
          >
            <span class="font-display text-[10px] uppercase tracking-[0.2em] text-white/40">On This Page</span>
            <svg id="toc-chevron" class="h-3.5 w-3.5 text-white/30 transition-transform duration-200" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7" />
            </svg>
          </button>

          <!-- TOC list -->
          <nav id="toc-list" class="border border-t-0 border-white/10 bg-white/[0.015] px-4 py-3">
            <ul class="space-y-0.5">
              {tocHeadings.map((h) => (
                <li>
                  <a
                    href={`#${h.slug}`}
                    class="toc-link block py-1.5 font-display text-[10.5px] uppercase tracking-[0.14em] text-white/40 transition-colors duration-150 hover:text-accent-blue"
                    data-slug={h.slug}
                  >
                    {h.text}
                  </a>
                </li>
              ))}
            </ul>
          </nav>
        </aside>
      )}

      <!-- Spacer: compensates for fixed TOC bar height on mobile (hidden on desktop) -->
      <div id="toc-spacer" class="lg:hidden"></div>

      <!-- Main content column -->
      <div>

        <!-- PART 2 — PROJECT FOCUS -->
        {d.focusCards && d.focusCards.length > 0 ? (
          <section aria-label="Project Focus">
            <h2 class="border-b border-white/8 pb-2 font-display text-[1.15rem] font-bold uppercase tracking-[0.12em] text-white/90">What This Project Focused On</h2>
            <div class="mt-6 grid gap-4 sm:grid-cols-2">
              {d.focusCards.map((card) => (
                <div class="border border-white/10 bg-white/[0.02] p-5">
                  <h3 class="font-display text-[12px] font-bold uppercase tracking-[0.15em] text-accent-blue">{card.title}</h3>
                  <p class="mt-2 text-[0.93rem] leading-6 text-white/60">{card.description}</p>
                </div>
              ))}
            </div>
          </section>
        ) : d.highlights.length > 0 && (
          <section class="border-l-2 border-accent-blue/30 pl-6" aria-label="Key Highlights">
            <p class="font-display text-[13px] uppercase tracking-[0.2em] text-white/40">Key Highlights</p>
            <ul class="mt-5 space-y-3">
              {d.highlights.map((h) => (
                <li class="flex gap-3 text-[1.06rem] leading-8 text-white/68">
                  <span class="mt-2 h-1.5 w-1.5 shrink-0 rounded-full bg-accent-blue" aria-hidden="true"></span>
                  {h}
                </li>
              ))}
            </ul>
          </section>
        )}

        <!-- PART 3 — FULL BREAKDOWN -->
        <article class="prose-portfolio mt-16" aria-label="Full Breakdown" data-base={base}>
          <Content />
        </article>

      </div>

    </div>

  </main>
</SiteLayout>

<style>
  .prose-portfolio :global(h2) {
    font-family: var(--font-display);
    font-size: 1.15rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    color: rgba(255, 255, 255, 0.9);
    margin-top: 2.5rem;
    margin-bottom: 0.75rem;
    padding-bottom: 0.5rem;
    border-bottom: 1px solid rgba(255, 255, 255, 0.08);
  }
  .prose-portfolio :global(h3) {
    font-family: var(--font-display);
    font-size: 0.95rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: rgba(74, 158, 255, 0.85);
    margin-top: 1.75rem;
    margin-bottom: 0.5rem;
  }
  .prose-portfolio :global(p) {
    font-size: 1.04rem;
    line-height: 1.85;
    color: rgba(255, 255, 255, 0.62);
    margin-bottom: 1rem;
  }
  .prose-portfolio :global(ul) {
    list-style: none;
    padding: 0;
    margin-bottom: 1rem;
  }
  .prose-portfolio :global(li) {
    font-size: 1rem;
    line-height: 1.75;
    color: rgba(255, 255, 255, 0.62);
    padding-left: 1.25rem;
    position: relative;
    margin-bottom: 0.4rem;
  }
  .prose-portfolio :global(li)::before {
    content: '–';
    position: absolute;
    left: 0;
    color: rgba(74, 158, 255, 0.6);
  }
  .prose-portfolio :global(strong) {
    color: rgba(255, 255, 255, 0.85);
    font-weight: 600;
  }
  .prose-portfolio :global(a) {
    color: #4a9eff;
    text-decoration: underline;
    text-underline-offset: 3px;
  }
  .prose-portfolio :global(a:hover) {
    color: #fff;
  }
  .prose-portfolio :global(ol) {
    list-style: none;
    padding: 0;
    margin-bottom: 1rem;
    counter-reset: ol-counter;
  }
  .prose-portfolio :global(ol > li) {
    counter-increment: ol-counter;
    padding-left: 2rem;
  }
  .prose-portfolio :global(ol > li)::before {
    content: counter(ol-counter) '.';
    position: absolute;
    left: 0;
    color: rgba(74, 158, 255, 0.7);
    font-family: var(--font-display);
    font-size: 0.85rem;
  }
  .prose-portfolio :global(table) {
    width: 100%;
    border-collapse: collapse;
    margin: 1.5rem 0;
    font-size: 0.9rem;
  }
  .prose-portfolio :global(th) {
    font-family: var(--font-body);
    font-size: 0.82rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: rgba(255, 255, 255, 0.55);
    padding: 0.5rem 0.75rem;
    border-bottom: 1px solid rgba(255, 255, 255, 0.1);
    text-align: left;
  }
  .prose-portfolio :global(td) {
    padding: 0.6rem 0.75rem;
    border-bottom: 1px solid rgba(255, 255, 255, 0.05);
    color: rgba(255, 255, 255, 0.6);
    vertical-align: top;
  }
  .prose-portfolio :global(tr:last-child td) {
    border-bottom: none;
  }
  .prose-portfolio :global(.build-matrix table) {
    text-align: center;
  }
  .prose-portfolio :global(.build-matrix th),
  .prose-portfolio :global(.build-matrix td) {
    text-align: center;
    vertical-align: middle;
  }
  .prose-portfolio :global(.build-matrix thead th) {
    color: rgba(255, 255, 255, 0.85);
  }
  .prose-portfolio :global(.build-matrix tbody th) {
    font-family: var(--font-body);
    font-size: 0.82rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: rgba(255, 255, 255, 0.85);
    border-bottom: 1px solid rgba(255, 255, 255, 0.08);
    border-right: 1px solid rgba(255, 255, 255, 0.08);
    padding: 0.6rem 0.75rem;
  }
  .prose-portfolio :global(.build-matrix tr:last-child th),
  .prose-portfolio :global(.build-matrix tr:last-child td) {
    border-bottom: none;
  }
  .prose-portfolio :global(.build-matrix td:first-child) {
    font-family: var(--font-body);
    font-size: 0.82rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: rgba(255, 255, 255, 0.55);
    border-bottom: 1px solid rgba(255, 255, 255, 0.05);
  }
  .prose-portfolio :global(.build-matrix tr:last-child td:first-child) {
    border-bottom: none;
  }
  .prose-portfolio :global(.build-matrix td:first-child strong) {
    font-weight: 600;
  }
  .prose-portfolio :global(.th-sub) {
    display: block;
    font-size: 0.72rem;
    font-weight: 400;
    text-transform: none;
    letter-spacing: 0.02em;
    color: rgba(255, 255, 255, 0.38);
    margin-top: 0.2rem;
  }
  .prose-portfolio :global(.content-media) {
    width: 100%;
    max-height: 420px;
    display: block;
    object-fit: contain;
    border: 1px solid rgba(255, 255, 255, 0.08);
    background: rgba(255, 255, 255, 0.015);
    margin: 1.25rem 0 2rem;
  }
  .prose-portfolio :global(.media-grid) {
    display: grid;
    gap: 0.9rem;
    margin: 1.25rem 0 2rem;
  }
  .prose-portfolio :global(.media-grid-2) {
    grid-template-columns: repeat(2, minmax(0, 1fr));
  }
  .prose-portfolio :global(.media-grid-3) {
    grid-template-columns: repeat(3, minmax(0, 1fr));
  }
  .prose-portfolio :global(.media-grid .content-media) {
    margin: 0;
    max-height: 360px;
  }
  .prose-portfolio :global(.media-grid figure) {
    margin: 0;
    display: grid;
    gap: 0.45rem;
  }
  .prose-portfolio :global(.media-grid figcaption) {
    margin: 0;
    font-size: 0.82rem;
    line-height: 1.35;
    color: color-mix(in srgb, var(--color-muted) 82%, #fff 18%);
    text-align: center;
  }
  .prose-portfolio :global(.media-grid .content-media.compact-compare) {
    width: 78%;
    justify-self: center;
    max-height: 210px;
  }
  @media (max-width: 900px) {
    .prose-portfolio :global(.media-grid-2),
    .prose-portfolio :global(.media-grid-3) {
      grid-template-columns: minmax(0, 1fr);
    }
  }
  .prose-portfolio :global(.media-placeholder) {
    margin: 1.5rem 0 2rem;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    min-height: 200px;
    border: 1px dashed rgba(255, 255, 255, 0.12);
    background: rgba(255, 255, 255, 0.015);
    gap: 0.5rem;
  }
  .prose-portfolio :global(.media-placeholder::before) {
    content: '';
    display: block;
    width: 28px;
    height: 28px;
    border: 1.5px solid rgba(255,255,255,0.18);
    border-radius: 4px;
    background: rgba(74,158,255,0.06);
  }
  .prose-portfolio :global(.media-placeholder::after) {
    content: attr(data-label);
    font-family: var(--font-display);
    font-size: 10px;
    text-transform: uppercase;
    letter-spacing: 0.2em;
    color: rgba(255, 255, 255, 0.2);
    text-align: center;
    padding: 0 1rem;
  }
  .prose-portfolio :global(.va-grid-carousel) {
    margin: 1.5rem 0 2rem;
    border: 1px solid rgba(255, 255, 255, 0.1);
    background: rgba(255, 255, 255, 0.02);
    padding: 0.75rem;
    display: grid;
    gap: 0.85rem;
  }
  .prose-portfolio :global(.va-grid-carousel-stage) {
    display: grid;
    grid-template-columns: auto minmax(0, 1fr) auto;
    align-items: center;
    gap: 0.65rem;
  }
  .prose-portfolio :global(.va-grid-carousel-viewport) {
    min-width: 0;
    --va-carousel-height: 420px;
  }
  .prose-portfolio :global(.va-grid-carousel-slide) {
    margin: 0;
    display: none;
    gap: 0.55rem;
  }
  .prose-portfolio :global(.va-grid-carousel-slide.is-active) {
    display: grid;
    animation-duration: 560ms;
    animation-timing-function: cubic-bezier(0.22, 0.61, 0.36, 1);
    animation-fill-mode: both;
    will-change: transform, opacity;
  }
  .prose-portfolio :global(.va-grid-carousel-slide.is-active.va-slide-in-right) {
    animation-name: vaSlideInFromRight;
  }
  .prose-portfolio :global(.va-grid-carousel-slide.is-active.va-slide-in-left) {
    animation-name: vaSlideInFromLeft;
  }
  .prose-portfolio :global(.va-grid-carousel-zoom) {
    margin: 0;
    padding: 0;
    border: 0;
    background: transparent;
    width: 100%;
    min-height: var(--va-carousel-height);
    display: flex;
    align-items: center;
    justify-content: center;
    text-align: inherit;
    cursor: zoom-in;
    background: rgba(255, 255, 255, 0.05);
  }
  .prose-portfolio :global(.va-grid-carousel-image) {
    width: 100%;
    height: var(--va-carousel-height);
    display: block;
    object-fit: contain;
    border: 1px solid rgba(255, 255, 255, 0.12);
    background: rgba(255, 255, 255, 0.12);
  }
  .prose-portfolio :global(.va-grid-carousel-slide figcaption) {
    margin: 0;
    min-height: 2.6em;
    font-size: 0.84rem;
    line-height: 1.4;
    color: color-mix(in srgb, var(--color-muted) 82%, #fff 18%);
    text-align: center;
  }
  .prose-portfolio :global(.va-grid-carousel-nav) {
    width: 2.45rem;
    height: 8rem;
    border: 1px solid rgba(74, 158, 255, 0.48);
    border-radius: 2px;
    background: color-mix(in srgb, var(--color-page-bg) 85%, #4a9eff 15%);
    box-shadow: none;
    color: #bfe3ff;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    cursor: pointer;
    transition: border-color 180ms ease, color 180ms ease, background-color 180ms ease, transform 180ms ease;
  }
  .prose-portfolio :global(.va-grid-carousel-nav:hover) {
    border-color: rgba(120, 198, 255, 0.85);
    color: #ffffff;
    background: color-mix(in srgb, var(--color-page-bg) 72%, #4a9eff 28%);
    transform: translateY(-1px);
  }
  .prose-portfolio :global(.va-grid-carousel-nav:active) {
    transform: translateY(0);
    background: color-mix(in srgb, var(--color-page-bg) 68%, #4a9eff 32%);
  }
  .prose-portfolio :global(.va-grid-carousel-dots) {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 0.45rem;
  }
  .prose-portfolio :global(.va-grid-carousel-dot) {
    width: 0.58rem;
    height: 0.58rem;
    border-radius: 999px;
    border: 1px solid rgba(255, 255, 255, 0.35);
    background: transparent;
    cursor: pointer;
  }
  .prose-portfolio :global(.va-grid-carousel-dot.is-active) {
    background: #4a9eff;
    border-color: #4a9eff;
  }
  .prose-portfolio :global(.va-standalone-figure) {
    margin: 1.25rem 0 2rem;
    display: grid;
    gap: 0.55rem;
  }
  .prose-portfolio :global(.va-standalone-zoom) {
    margin: 0;
    padding: 0;
    border: 0;
    background: transparent;
    width: 100%;
    display: block;
    cursor: zoom-in;
  }
  .prose-portfolio :global(.va-standalone-zoom .content-media) {
    margin: 0;
  }
  .prose-portfolio :global(.va-standalone-figure figcaption) {
    margin: 0;
    font-size: 0.84rem;
    line-height: 1.4;
    color: color-mix(in srgb, var(--color-muted) 82%, #fff 18%);
    text-align: center;
  }
  :global(.va-lightbox.is-standalone .va-lightbox-controls) {
    display: none;
  }
  :global(.va-lightbox) {
    position: fixed;
    inset: 0;
    z-index: 120;
    display: none;
    align-items: center;
    justify-content: center;
    background: rgba(3, 8, 16, 0.9);
    padding: 2rem 1rem;
  }
  :global(.va-lightbox.is-open) {
    display: flex;
  }
  :global(.va-lightbox-frame) {
    width: min(1200px, 96vw);
    max-height: 92vh;
    background: rgba(11, 16, 28, 0.92);
    border: 1px solid rgba(255, 255, 255, 0.18);
    padding: 0.9rem;
    display: grid;
    gap: 0.75rem;
  }
  :global(.va-lightbox-image) {
    width: 100%;
    height: var(--va-lightbox-height, calc(92vh - 13rem));
    max-height: calc(92vh - 13rem);
    object-fit: contain;
    display: block;
    background: rgba(255, 255, 255, 0.02);
    border: 1px solid rgba(255, 255, 255, 0.1);
    will-change: transform, opacity;
  }
  :global(.va-lightbox-image.va-slide-in-right) {
    animation: vaLightboxSlideInRight 560ms cubic-bezier(0.22, 0.61, 0.36, 1) both;
  }
  :global(.va-lightbox-image.va-slide-in-left) {
    animation: vaLightboxSlideInLeft 560ms cubic-bezier(0.22, 0.61, 0.36, 1) both;
  }
  :global(.va-lightbox-close) {
    justify-self: end;
    border: 1px solid rgba(255, 255, 255, 0.28);
    background: rgba(255, 255, 255, 0.08);
    color: #fff;
    font-family: var(--font-display);
    font-size: 0.72rem;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    padding: 0.3rem 0.55rem;
    cursor: pointer;
  }
  :global(.va-lightbox-caption) {
    margin: 0;
    min-height: 2.6em;
    font-size: 0.82rem;
    line-height: 1.35;
    color: rgba(255, 255, 255, 0.76);
    text-align: center;
  }
  :global(.va-lightbox-controls) {
    display: grid;
    grid-template-columns: auto 1fr auto;
    align-items: center;
    gap: 0.8rem;
  }
  :global(.va-lightbox-nav) {
    width: 2.45rem;
    height: 2.5rem;
    border: 1px solid rgba(74, 158, 255, 0.55);
    border-radius: 2px;
    background: rgba(11, 20, 38, 0.95);
    box-shadow: none;
    color: #bfe3ff;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    cursor: pointer;
    transition: border-color 180ms ease, color 180ms ease, background-color 180ms ease, transform 180ms ease;
  }
  :global(.va-lightbox-nav:hover) {
    border-color: rgba(120, 198, 255, 0.85);
    color: #ffffff;
    background: rgba(20, 38, 66, 0.98);
    transform: translateY(-1px);
  }
  :global(.va-lightbox-nav:active) {
    transform: translateY(0);
    background: rgba(26, 48, 80, 0.98);
  }
  :global(.va-nav-triangle) {
    display: block;
    width: 0.78rem;
    height: 0.92rem;
    background: currentColor;
  }
  :global(.va-nav-triangle-left) {
    clip-path: polygon(0 50%, 100% 0, 100% 100%);
  }
  :global(.va-nav-triangle-right) {
    clip-path: polygon(100% 50%, 0 0, 0 100%);
  }
  :global(.va-lightbox-dots) {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 0.45rem;
  }
  :global(.va-lightbox-dot) {
    width: 0.58rem;
    height: 0.58rem;
    border-radius: 999px;
    border: 1px solid rgba(255, 255, 255, 0.35);
    background: transparent;
    cursor: pointer;
  }
  :global(.va-lightbox-dot.is-active) {
    background: #4a9eff;
    border-color: #4a9eff;
  }
  @keyframes vaSlideInFromRight {
    from {
      opacity: 0.45;
      transform: translateX(10%);
    }
    to {
      opacity: 1;
      transform: translateX(0);
    }
  }
  @keyframes vaSlideInFromLeft {
    from {
      opacity: 0.45;
      transform: translateX(-10%);
    }
    to {
      opacity: 1;
      transform: translateX(0);
    }
  }
  @keyframes vaLightboxSlideInRight {
    from {
      opacity: 0.38;
      transform: translateX(9%);
    }
    to {
      opacity: 1;
      transform: translateX(0);
    }
  }
  @keyframes vaLightboxSlideInLeft {
    from {
      opacity: 0.38;
      transform: translateX(-9%);
    }
    to {
      opacity: 1;
      transform: translateX(0);
    }
  }
  @media (max-width: 900px) {
    .prose-portfolio :global(.va-grid-carousel-nav) {
      width: 1.85rem;
      height: 1.85rem;
    }
  }
  .prose-portfolio :global(hr) {
    border: none;
    border-top: 1px solid rgba(255,255,255,0.07);
    margin: 2.5rem 0;
  }
  /* TOC active link */
  #toc-list a.toc-active {
    color: #4a9eff;
  }
  /* TOC collapsed state */
  #toc-list.toc-collapsed {
    display: none;
  }
  /* Rotate chevron when collapsed */
  #toc-chevron.toc-chevron-collapsed {
    transform: rotate(-90deg);
  }
</style>

<script>
  // ── Markdown media path fix for base URL ───────────────────────────
  const prose = document.querySelector('.prose-portfolio');
  const basePath = prose?.getAttribute('data-base') ?? '';
  if (prose && basePath) {
    const mediaEls = prose.querySelectorAll('img[src^="/"], video[src^="/"], source[src^="/"]');
    mediaEls.forEach((el) => {
      const attr = el.tagName.toLowerCase() === 'source' ? 'src' : 'src';
      const raw = el.getAttribute(attr);
      if (!raw) return;
      // Avoid double-prefixing if the path already contains the base segment.
      if (raw.startsWith(`${basePath}/`) || raw === basePath) return;
      el.setAttribute(attr, `${basePath}${raw}`);
    });
  }

  // ── Hero media fallback: YouTube iframe -> local mp4 ──────────────
  const demoVideoBlocks = document.querySelectorAll<HTMLElement>('[data-demo-video-block]');
  demoVideoBlocks.forEach((block) => {
    const media = block.querySelector<HTMLElement>('[data-demo-media]');
    const iframe = block.querySelector<HTMLIFrameElement>('[data-demo-iframe]');
    const fallback = block.querySelector<HTMLVideoElement>('[data-demo-fallback]');
    if (!media || !iframe || !fallback) return;

    let resolved = false;
    const revealFallback = () => {
      if (resolved) return;
      resolved = true;
      iframe.classList.add('hidden');
      fallback.classList.remove('hidden');
      fallback.muted = false;
      fallback.volume = 0.5;
    };

    const markLoaded = () => {
      if (resolved) return;
      resolved = true;
    };

    // If embed is blocked or never finishes, switch to local media.
    const fallbackTimer = window.setTimeout(() => {
      if (!resolved) revealFallback();
    }, 5000);

    iframe.addEventListener('load', () => {
      // Set YouTube player to unmuted 50% volume once embed is ready.
      window.setTimeout(() => {
        iframe.contentWindow?.postMessage(
          JSON.stringify({ event: 'command', func: 'unMute', args: [] }),
          '*',
        );
        iframe.contentWindow?.postMessage(
          JSON.stringify({ event: 'command', func: 'setVolume', args: [50] }),
          '*',
        );
      }, 800);
      window.clearTimeout(fallbackTimer);
      markLoaded();
    });

    iframe.addEventListener('error', () => {
      window.clearTimeout(fallbackTimer);
      revealFallback();
    });
  });

  // ── TOC: collapse / expand ──────────────────────────────────────────
  const toggle = document.getElementById('toc-toggle');
  const list   = document.getElementById('toc-list');
  const chevron = document.getElementById('toc-chevron');

  if (toggle && list && chevron) {
    // Mobile default: collapsed
    const isDesktop = () => window.innerWidth >= 1024;
    if (!isDesktop()) {
      list.classList.add('toc-collapsed');
      chevron.classList.add('toc-chevron-collapsed');
      toggle.setAttribute('aria-expanded', 'false');
    }

    toggle.addEventListener('click', () => {
      const collapsed = list.classList.toggle('toc-collapsed');
      chevron.classList.toggle('toc-chevron-collapsed', collapsed);
      toggle.setAttribute('aria-expanded', String(!collapsed));
      // Lock: prevent the micro-scroll from this tap hiding the TOC
      tocLocked = true;
      clearTimeout(tocLockTimer);
      tocLockTimer = window.setTimeout(() => { tocLocked = false; }, 600);
    });
  }

  // ── TOC: scroll spy ────────────────────────────────────────────────
  const tocLinks = document.querySelectorAll<HTMLAnchorElement>('a.toc-link');
  if (tocLinks.length > 0) {
    const headingEls = Array.from(tocLinks)
      .map((a) => document.getElementById(a.dataset.slug ?? ''))
      .filter(Boolean) as HTMLElement[];

    const setActive = (id: string) => {
      tocLinks.forEach((a) => {
        a.classList.toggle('toc-active', a.dataset.slug === id);
      });
    };

    const getSpyOffset = () => {
      const headerEl = document.querySelector<HTMLElement>('[data-site-header]');
      const tocAsideEl = document.getElementById('toc-aside') as HTMLElement | null;
      const headerH = headerEl?.offsetHeight ?? 0;
      const mobileTocH = window.innerWidth < 1024 ? (tocAsideEl?.offsetHeight ?? 0) : 0;
      return headerH + mobileTocH + 24;
    };

    const updateActiveByScroll = () => {
      if (headingEls.length === 0) return;
      const offset = getSpyOffset();
      let currentId = headingEls[0].id;

      for (const el of headingEls) {
        if (el.getBoundingClientRect().top - offset <= 0) {
          currentId = el.id;
        } else {
          break;
        }
      }

      setActive(currentId);
    };

    let spyTick = false;
    const onSpyChange = () => {
      if (spyTick) return;
      spyTick = true;
      window.requestAnimationFrame(() => {
        updateActiveByScroll();
        spyTick = false;
      });
    };

    window.addEventListener('scroll', onSpyChange, { passive: true });
    window.addEventListener('resize', onSpyChange);
    updateActiveByScroll();
  }

  // Shared lock: set by toggle click to ignore the micro-scroll that follows
  let tocLocked = false;
  let tocLockTimer = 0;

  // ── TOC: mobile hide/show ─────────────────────────────────────────
  const tocAside = document.getElementById('toc-aside');
  const tocSpacer = document.getElementById('toc-spacer');
  const siteHeader = document.querySelector<HTMLElement>('[data-site-header]');
  if (tocAside && siteHeader) {
    const mq = window.matchMedia('(max-width: 1023px)');
    if (mq.matches) {
      // Position fixed bar flush below the real header
      const headerH = siteHeader.offsetHeight;
      tocAside.style.top = `${headerH}px`;
      // Spacer fills the gap the fixed element leaves behind
      if (tocSpacer) tocSpacer.style.height = `${tocAside.offsetHeight}px`;

      let lastTocScrollY = window.scrollY;
      let tocTick = false;
      let tocHidden = false;
      const DELTA = 8;
      const TOP_OFFSET = 24;

      const updateToc = () => {
        const y = window.scrollY;
        const d = y - lastTocScrollY;

        if (y <= TOP_OFFSET) {
          if (tocHidden) { tocAside.style.transform = ''; tocHidden = false; }
        } else if (d > DELTA && !tocHidden && !tocLocked) {
          // Hide: push bar above the viewport (headerH + its own height)
          tocAside.style.transform = `translateY(-${headerH + tocAside.offsetHeight + 8}px)`;
          tocHidden = true;
          if (list && chevron && toggle) {
            list.classList.add('toc-collapsed');
            chevron.classList.add('toc-chevron-collapsed');
            toggle.setAttribute('aria-expanded', 'false');
          }
        } else if (d < -DELTA && tocHidden) {
          tocAside.style.transform = '';
          tocHidden = false;
        }

        lastTocScrollY = y;
        tocTick = false;
      };

      window.addEventListener('scroll', () => {
        if (!tocTick) { window.requestAnimationFrame(updateToc); tocTick = true; }
      }, { passive: true });
    }
  }

  // ── Core Systems carousel: stable height + transitions + lightbox ─
  const carousels = document.querySelectorAll<HTMLElement>('[data-va-carousel]');
  if (carousels.length > 0) {
    const lightbox = document.createElement('div');
    lightbox.className = 'va-lightbox';
    lightbox.innerHTML = `
      <div class="va-lightbox-frame">
        <button type="button" class="va-lightbox-close" aria-label="Close large image">Close</button>
        <img class="va-lightbox-image" alt="" />
        <p class="va-lightbox-caption"></p>
        <div class="va-lightbox-controls" aria-label="Large image controls">
          <button type="button" class="va-lightbox-nav" data-lightbox-prev aria-label="Previous large image"><span class="va-nav-triangle va-nav-triangle-left" aria-hidden="true"></span></button>
          <div class="va-lightbox-dots" data-lightbox-dots></div>
          <button type="button" class="va-lightbox-nav" data-lightbox-next aria-label="Next large image"><span class="va-nav-triangle va-nav-triangle-right" aria-hidden="true"></span></button>
        </div>
      </div>
    `;
    document.body.appendChild(lightbox);

    const lightboxImage = lightbox.querySelector<HTMLImageElement>('.va-lightbox-image');
    const lightboxCaption = lightbox.querySelector<HTMLParagraphElement>('.va-lightbox-caption');
    const closeLightboxBtn = lightbox.querySelector<HTMLButtonElement>('.va-lightbox-close');
    const lightboxPrevBtn = lightbox.querySelector<HTMLButtonElement>('[data-lightbox-prev]');
    const lightboxNextBtn = lightbox.querySelector<HTMLButtonElement>('[data-lightbox-next]');
    const lightboxDotsWrap = lightbox.querySelector<HTMLElement>('[data-lightbox-dots]');

    type CarouselState = {
      carousel: HTMLElement;
      slides: HTMLElement[];
      dots: HTMLButtonElement[];
      images: HTMLImageElement[];
      prevBtn: HTMLButtonElement | null;
      nextBtn: HTMLButtonElement | null;
      index: number;
      direction: 'next' | 'prev';
      autoMs: number;
      timer: number | null;
      setSlide: (nextIndex: number) => void;
      restartAutoplay: () => void;
      stopAutoplay: () => void;
      ensureStableHeight: () => void;
    };

    const states: CarouselState[] = [];
    let activeLightboxState: CarouselState | null = null;

    const isLightboxOpen = () => lightbox.classList.contains('is-open');

    const stopAllAutoplay = () => {
      states.forEach((state) => state.stopAutoplay());
    };

    const restartEligibleAutoplay = () => {
      states.forEach((state) => {
        if (!state.carousel.matches(':hover') && !state.carousel.contains(document.activeElement)) {
          state.restartAutoplay();
        }
      });
    };

    const getSlideData = (state: CarouselState) => {
      const slide = state.slides[state.index];
      const btn = slide.querySelector<HTMLButtonElement>('.va-grid-carousel-zoom');
      const img = slide.querySelector<HTMLImageElement>('img');
      const caption = slide.querySelector('figcaption')?.textContent?.trim() ?? '';
      const src = btn?.dataset.lightboxSrc ?? img?.getAttribute('src') ?? '';
      return { src, caption, alt: img?.alt ?? '' };
    };

    const renderLightboxControls = (state: CarouselState) => {
      if (!lightboxDotsWrap) return;
      lightboxDotsWrap.innerHTML = '';
      state.slides.forEach((_, i) => {
        const dot = document.createElement('button');
        dot.type = 'button';
        dot.className = `va-lightbox-dot${i === state.index ? ' is-active' : ''}`;
        dot.setAttribute('aria-label', `Show large image ${i + 1}`);
        dot.addEventListener('click', () => {
          state.setSlide(i);
          renderLightboxContent(state);
        });
        lightboxDotsWrap.appendChild(dot);
      });
    };

    const renderLightboxContent = (state: CarouselState) => {
      if (!lightboxImage) return;
      const data = getSlideData(state);
      if (!data.src) return;
      const normalizedSrc = data.src.startsWith(`${basePath}/`) || data.src === basePath ? data.src : `${basePath}${data.src}`;
      lightboxImage.classList.remove('va-slide-in-right', 'va-slide-in-left');
      void lightboxImage.offsetWidth;
      lightboxImage.classList.add(state.direction === 'next' ? 'va-slide-in-right' : 'va-slide-in-left');
      lightboxImage.src = normalizedSrc;
      lightboxImage.alt = data.alt;
      if (lightboxCaption) lightboxCaption.textContent = data.caption;
      renderLightboxControls(state);
    };

    const syncLightboxHeight = (state: CarouselState) => {
      const frame = lightbox.querySelector<HTMLElement>('.va-lightbox-frame');
      if (!frame) return;

      const getLightboxMaxImageSpace = () => {
        const frameStyles = window.getComputedStyle(frame);
        const padTop = parseFloat(frameStyles.paddingTop || '0') || 0;
        const padBottom = parseFloat(frameStyles.paddingBottom || '0') || 0;
        const rowGap = parseFloat(frameStyles.rowGap || frameStyles.gap || '0') || 0;
        const closeH = closeLightboxBtn?.offsetHeight ?? 0;
        const captionH = lightboxCaption?.offsetHeight ?? 0;
        const controlsH = lightbox.querySelector<HTMLElement>('.va-lightbox-controls')?.offsetHeight ?? 0;
        const reserved = padTop + padBottom + closeH + captionH + controlsH + rowGap * 3 + 24;
        return Math.max(240, window.innerHeight * 0.92 - reserved);
      };

      const frameWidth = Math.min(1200, window.innerWidth * 0.96) - 28;
      const maxSpace = getLightboxMaxImageSpace();
      let target = 0;

      state.images.forEach((img) => {
        if (img.naturalWidth > 0 && img.naturalHeight > 0) {
          const rendered = (frameWidth * img.naturalHeight) / img.naturalWidth;
          if (rendered > target) target = rendered;
        }
      });

      if (target <= 0) {
        lightbox.style.removeProperty('--va-lightbox-height');
        return;
      }

      const clamped = Math.min(Math.max(target, 280), Math.max(280, maxSpace));
      lightbox.style.setProperty('--va-lightbox-height', `${Math.round(clamped)}px`);
    };

    const closeLightbox = () => {
      lightbox.classList.remove('is-open', 'is-standalone');
      document.body.style.overflow = '';
      lightbox.style.removeProperty('--va-lightbox-height');
      restartEligibleAutoplay();
      activeLightboxState = null;
    };

    lightbox.addEventListener('pointerenter', stopAllAutoplay);
    lightbox.addEventListener('focusin', stopAllAutoplay);
    lightbox.addEventListener('pointerleave', () => {
      if (isLightboxOpen()) return;
      restartEligibleAutoplay();
    });
    lightbox.addEventListener('focusout', () => {
      if (isLightboxOpen()) return;
      restartEligibleAutoplay();
    });

    closeLightboxBtn?.addEventListener('click', closeLightbox);
    lightbox.addEventListener('click', (event) => {
      if (event.target === lightbox) closeLightbox();
    });

    lightboxPrevBtn?.addEventListener('click', () => {
      if (!activeLightboxState) return;
      activeLightboxState.setSlide(activeLightboxState.index - 1);
      renderLightboxContent(activeLightboxState);
    });

    lightboxNextBtn?.addEventListener('click', () => {
      if (!activeLightboxState) return;
      activeLightboxState.setSlide(activeLightboxState.index + 1);
      renderLightboxContent(activeLightboxState);
    });

    window.addEventListener('keydown', (event) => {
      if (!lightbox.classList.contains('is-open')) return;
      if (event.key === 'Escape') {
        closeLightbox();
        return;
      }
      if (!activeLightboxState) return;
      if (event.key === 'ArrowLeft') {
        activeLightboxState.setSlide(activeLightboxState.index - 1);
        renderLightboxContent(activeLightboxState);
      } else if (event.key === 'ArrowRight') {
        activeLightboxState.setSlide(activeLightboxState.index + 1);
        renderLightboxContent(activeLightboxState);
      }
    });

    window.addEventListener('resize', () => {
      if (activeLightboxState && isLightboxOpen()) {
        syncLightboxHeight(activeLightboxState);
      }
    });

    carousels.forEach((carousel) => {
      const slides = Array.from(carousel.querySelectorAll<HTMLElement>('.va-grid-carousel-slide'));
      const dots = Array.from(carousel.querySelectorAll<HTMLButtonElement>('.va-grid-carousel-dot'));
      const images = Array.from(carousel.querySelectorAll<HTMLImageElement>('.va-grid-carousel-image'));
      const prevBtn = carousel.querySelector<HTMLButtonElement>('[data-carousel-prev]');
      const nextBtn = carousel.querySelector<HTMLButtonElement>('[data-carousel-next]');
      const viewport = carousel.querySelector<HTMLElement>('.va-grid-carousel-viewport');

      const autoMsRaw = Number(carousel.dataset.autoMs);
      const autoMs = Number.isFinite(autoMsRaw) && autoMsRaw > 0 ? autoMsRaw : 5000;

      if (slides.length <= 1) {
        prevBtn?.setAttribute('hidden', 'true');
        nextBtn?.setAttribute('hidden', 'true');
      }

      let index = slides.findIndex((slide) => slide.classList.contains('is-active'));
      if (index < 0) index = 0;
      let timer: number | null = null;
      let lastDirection: 'next' | 'prev' = 'next';

      const setSlide = (nextIndex: number) => {
        const wrapped = (nextIndex + slides.length) % slides.length;
        const previous = index;
        if (wrapped === previous) return;

        // Direction follows caller intent (next/prev for arrows+autoplay, index compare for dots).
        if (nextIndex > previous) {
          lastDirection = 'next';
        } else if (nextIndex < previous) {
          lastDirection = 'prev';
        }
        state.direction = lastDirection;

        index = wrapped;
        state.index = wrapped;

        slides.forEach((slide, i) => {
          slide.classList.toggle('is-active', i === wrapped);
          slide.classList.remove('va-slide-in-right', 'va-slide-in-left');
          if (i === wrapped) {
            slide.classList.add(lastDirection === 'next' ? 'va-slide-in-right' : 'va-slide-in-left');
          }
        });

        dots.forEach((dot, i) => {
          const active = i === wrapped;
          dot.classList.toggle('is-active', active);
          dot.setAttribute('aria-current', String(active));
        });

        if (activeLightboxState === state && lightbox.classList.contains('is-open')) {
          renderLightboxContent(state);
        }
      };

      const restartAutoplay = () => {
        if (isLightboxOpen()) return;
        if (timer !== null) window.clearInterval(timer);
        timer = window.setInterval(() => {
          setSlide(index + 1);
        }, autoMs);
      };

      const stopAutoplay = () => {
        if (timer !== null) window.clearInterval(timer);
        timer = null;
      };

      const ensureStableHeight = () => {
        if (!viewport) return;
        const viewportWidth = viewport.clientWidth;
        if (!viewportWidth) return;

        let maxHeight = 0;
        images.forEach((img) => {
          if (img.naturalWidth > 0 && img.naturalHeight > 0) {
            const rendered = (viewportWidth * img.naturalHeight) / img.naturalWidth;
            if (rendered > maxHeight) maxHeight = rendered;
          }
        });

        if (maxHeight <= 0) return;
        const maxAllowed = window.innerWidth < 900 ? 460 : 680;
        const clamped = Math.min(Math.max(maxHeight, 240), maxAllowed);
        carousel.style.setProperty('--va-carousel-height', `${Math.round(clamped)}px`);
      };

      const state: CarouselState = {
        carousel,
        slides,
        dots,
        images,
        prevBtn,
        nextBtn,
        index,
        direction: 'next',
        autoMs,
        timer,
        setSlide,
        restartAutoplay,
        stopAutoplay,
        ensureStableHeight,
      };

      prevBtn?.addEventListener('click', () => {
        setSlide(index - 1);
        restartAutoplay();
      });

      nextBtn?.addEventListener('click', () => {
        setSlide(index + 1);
        restartAutoplay();
      });

      dots.forEach((dot, i) => {
        dot.addEventListener('click', () => {
          setSlide(i);
          restartAutoplay();
        });
      });

      const zoomButtons = Array.from(carousel.querySelectorAll<HTMLButtonElement>('.va-grid-carousel-zoom'));
      zoomButtons.forEach((btn, i) => {
        btn.addEventListener('click', () => {
          setSlide(i);
          stopAllAutoplay();
          activeLightboxState = state;
          syncLightboxHeight(state);
          renderLightboxContent(state);
          lightbox.classList.add('is-open');
          document.body.style.overflow = 'hidden';
        });
      });

      carousel.addEventListener('pointerenter', stopAutoplay);
      carousel.addEventListener('pointerleave', restartAutoplay);
      // Fallback for environments that do not emit pointer events consistently.
      carousel.addEventListener('mouseenter', stopAutoplay);
      carousel.addEventListener('mouseleave', restartAutoplay);
      carousel.addEventListener('focusin', stopAutoplay);
      carousel.addEventListener('focusout', () => {
        if (isLightboxOpen()) return;
        if (!carousel.contains(document.activeElement)) restartAutoplay();
      });

      images.forEach((img) => {
        if (img.complete) {
          ensureStableHeight();
        } else {
          img.addEventListener('load', ensureStableHeight, { once: true });
        }
      });

      setSlide(index);
      ensureStableHeight();
      restartAutoplay();
      states.push(state);
    });

    window.addEventListener('resize', () => {
      states.forEach((state) => state.ensureStableHeight());
    });

    // ── Standalone zoomable images (outside carousels) ──────────────
    const syncStandaloneHeight = () => {
      if (!lightboxImage) return;
      const frame = lightbox.querySelector<HTMLElement>('.va-lightbox-frame');
      if (!frame) return;

      const frameStyles = window.getComputedStyle(frame);
      const padTop = parseFloat(frameStyles.paddingTop || '0') || 0;
      const padBottom = parseFloat(frameStyles.paddingBottom || '0') || 0;
      const rowGap = parseFloat(frameStyles.rowGap || frameStyles.gap || '0') || 0;
      const closeH = closeLightboxBtn?.offsetHeight ?? 0;
      const captionH = lightboxCaption?.offsetHeight ?? 0;
      const controlsH = lightbox.querySelector<HTMLElement>('.va-lightbox-controls')?.offsetHeight ?? 0;
      const reserved = padTop + padBottom + closeH + captionH + controlsH + rowGap * 3 + 24;

      const frameWidth = Math.min(1200, window.innerWidth * 0.96) - 28;
      const maxSpace = Math.max(240, window.innerHeight * 0.92 - reserved);
      if (lightboxImage.naturalWidth > 0 && lightboxImage.naturalHeight > 0) {
        const rendered = (frameWidth * lightboxImage.naturalHeight) / lightboxImage.naturalWidth;
        const clamped = Math.min(Math.max(rendered, 280), Math.max(280, maxSpace));
        lightbox.style.setProperty('--va-lightbox-height', `${Math.round(clamped)}px`);
      }
    };

    const standaloneZoomBtns = document.querySelectorAll<HTMLButtonElement>('.va-standalone-zoom');
    standaloneZoomBtns.forEach((btn) => {
      btn.addEventListener('click', () => {
        const src = btn.dataset.lightboxSrc ?? btn.querySelector('img')?.getAttribute('src') ?? '';
        const img = btn.querySelector<HTMLImageElement>('img');
        const caption = btn.closest('figure')?.querySelector('figcaption')?.textContent?.trim() ?? '';
        if (!src || !lightboxImage) return;
        const normalizedSrc = src.startsWith(`${basePath}/`) || src === basePath ? src : `${basePath}${src}`;
        lightboxImage.src = normalizedSrc;
        lightboxImage.alt = img?.alt ?? '';
        lightboxImage.classList.remove('va-slide-in-right', 'va-slide-in-left');
        if (lightboxCaption) lightboxCaption.textContent = caption;
        if (lightboxDotsWrap) lightboxDotsWrap.innerHTML = '';
        stopAllAutoplay();
        activeLightboxState = null;
        lightbox.style.removeProperty('--va-lightbox-height');
        lightbox.classList.add('is-open', 'is-standalone');
        document.body.style.overflow = 'hidden';
        if (lightboxImage.complete && lightboxImage.naturalWidth > 0) {
          syncStandaloneHeight();
        } else {
          lightboxImage.addEventListener('load', syncStandaloneHeight, { once: true });
        }
      });
    });

    window.addEventListener('resize', () => {
      if (activeLightboxState === null && lightbox.classList.contains('is-open')) {
        syncStandaloneHeight();
      }
    });
  }
</script>
