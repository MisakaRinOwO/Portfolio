---
import SiteLayout from '../layouts/SiteLayout.astro';
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
---

<SiteLayout
  title="Peter Xie — Gameplay Programmer"
  description="Gameplay Programmer with a focus on technical systems design, simulation, modular systems, and player-driven emergence."
>
  <!-- Hero -->
  <section class="relative flex min-h-[92svh] flex-col items-center justify-center overflow-hidden px-6 py-24 text-center">
    <!-- Avatar photo -->
    <div
      class="relative z-10 mb-8 h-44 w-44 overflow-hidden rounded-full border border-white/12 ring-1 ring-accent-blue/28 shadow-[0_0_56px_rgba(74,158,255,0.14)] sm:h-52 sm:w-52"
    >
      <img
        src={`${base}/brand/avatar2.jpeg`}
        alt="Peter Xie"
        class="h-full w-full object-cover"
        style="transform: scale(1.05) translateX(-2%);"
        width="800"
        height="800"
      />
    </div>

    <!-- Name -->
    <h1 class="relative z-10 font-display text-[2.5rem] font-bold leading-tight tracking-tight text-white sm:text-5xl lg:text-6xl">
      Peter <span class="text-white/40">(Ruilin)</span> Xie
    </h1>

    <!-- Alias -->
    <p class="relative z-10 mt-2 font-body text-[0.82rem] tracking-[0.12em] text-white/28">aka Rin Misaka</p>

    <!-- Role label -->
    <p class="relative z-10 mt-5 font-display text-sm uppercase tracking-[0.26em] text-accent-blue">
      Gameplay Programmer
    </p>

    <p class="relative z-10 mt-4 max-w-[46ch] text-[0.95rem] leading-[1.8] text-white/72 sm:text-[1rem]">
      Gameplay Programmer focused on technical systems design, simulation, modular systems, and player-driven emergence.
    </p>

    <!-- CTA -->
    <a
      href={`${base}/projects/`}
      class="relative z-10 mt-10 inline-flex min-h-[48px] items-center justify-center bg-accent-blue px-10 font-display text-[12px] uppercase tracking-[0.22em] text-white transition-all duration-300 hover:bg-white hover:text-page-bg"
    >
      View Projects
    </a>

    <!-- Poetic statement -->
    <blockquote
      class="relative z-10 mt-12 max-w-[56ch] border border-white/12 bg-white/[0.02] px-6 py-5 text-left text-[1.02rem] leading-[1.95] text-white/62 italic shadow-[0_14px_42px_rgba(5,8,12,0.28)] sm:px-7"
    >
      <span class="mb-3 block not-italic font-display text-[0.66rem] uppercase tracking-[0.2em] text-accent-blue/80">
        DESIGN NOTE // 01
      </span>
      <span class="block">
        Every game is a small universe with its own constants.
      </span>
      <span class="mt-2 block">
        I derive those constants — the pull between things, the melody of every orbit, how time remembers
        itself.
      </span>
      The system is Unreal. The resonance rests in Unity.
    </blockquote>

    <!-- Scroll hint line -->
    <div
      class="relative z-10 mt-12 h-10 w-px bg-[linear-gradient(to_bottom,rgba(74,158,255,0.4),transparent)]"
      aria-hidden="true"
    ></div>
  </section>
</SiteLayout>
