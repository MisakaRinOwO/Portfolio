---
import SiteLayout from '../layouts/SiteLayout.astro';
---

<SiteLayout
  title="Contact | Peter Xie"
  description="Get in touch with Peter Xie — Gameplay / Systems Engineer."
>
  <main class="mx-auto max-w-4xl px-6 py-16 sm:px-8 sm:py-20 lg:px-12 lg:py-24">

    <p class="font-display text-[13px] uppercase tracking-[0.22em] text-accent-blue">Contact</p>
    <h1 class="mt-4 font-display text-[2.4rem] font-bold leading-none text-white sm:text-5xl">
      Get in Touch
    </h1>
    <p class="mt-5 max-w-xl text-[1.04rem] leading-8 text-white/58">
      Open to full-time roles, internships, and collaborations on interesting game systems work.
      Best reached by email.
    </p>

    <!-- Contact cards -->
    <div class="mt-12 grid gap-4 sm:grid-cols-3">

      <!-- Email -->
      <a
        href="mailto:ruilinx.peter@gmail.com"
        class="group flex flex-col gap-4 border border-white/10 bg-white/[0.03] p-7 transition-colors duration-300 hover:border-accent-blue/40"
      >
        <div class="flex h-10 w-10 items-center justify-center rounded-full border border-white/12 bg-white/[0.05] text-white/60 transition-colors group-hover:border-accent-blue/40 group-hover:text-accent-blue">
          <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <rect width="20" height="16" x="2" y="4" rx="2"/>
            <path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"/>
          </svg>
        </div>
        <div>
          <p class="font-display text-[12px] uppercase tracking-[0.18em] text-white/40">Email</p>
          <p class="mt-2 text-[1.02rem] text-white/70 transition-colors group-hover:text-accent-blue">
            ruilinx.peter@gmail.com
          </p>
        </div>
      </a>

      <!-- GitHub -->
      <a
        href="https://github.com/MisakaRinOwO"
        target="_blank"
        rel="noopener noreferrer"
        class="group flex flex-col gap-4 border border-white/10 bg-white/[0.03] p-7 transition-colors duration-300 hover:border-accent-blue/40"
      >
        <div class="flex h-10 w-10 items-center justify-center rounded-full border border-white/12 bg-white/[0.05] text-white/60 transition-colors group-hover:border-accent-blue/40 group-hover:text-accent-blue">
          <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <path d="M15 22v-4a4.8 4.8 0 0 0-1-3.5c3 0 6-2 6-5.5.08-1.25-.27-2.48-1-3.5.28-1.15.28-2.35 0-3.5 0 0-1 0-3 1.5-2.64-.5-5.36-.5-8 0C6 2 5 2 5 2c-.3 1.15-.3 2.35 0 3.5A5.403 5.403 0 0 0 4 9c0 3.5 3 5.5 6 5.5-.39.49-.68 1.05-.85 1.65-.17.6-.22 1.23-.15 1.85v4"/>
            <path d="M9 18c-4.51 2-5-2-7-2"/>
          </svg>
        </div>
        <div>
          <p class="font-display text-[12px] uppercase tracking-[0.18em] text-white/40">GitHub</p>
          <p class="mt-2 text-[1.02rem] text-white/70 transition-colors group-hover:text-accent-blue">
            MisakaRinOwO
          </p>
        </div>
      </a>

      <!-- LinkedIn -->
      <a
        href="https://www.linkedin.com/in/ruilin-xie-a926aa249/"
        target="_blank"
        rel="noopener noreferrer"
        class="group flex flex-col gap-4 border border-white/10 bg-white/[0.03] p-7 transition-colors duration-300 hover:border-accent-blue/40"
      >
        <div class="flex h-10 w-10 items-center justify-center rounded-full border border-white/12 bg-white/[0.05] text-white/60 transition-colors group-hover:border-accent-blue/40 group-hover:text-accent-blue">
          <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <path d="M16 8a6 6 0 0 1 6 6v7h-4v-7a2 2 0 0 0-2-2 2 2 0 0 0-2 2v7h-4v-7a6 6 0 0 1 6-6z"/>
            <rect width="4" height="12" x="2" y="9"/>
            <circle cx="4" cy="4" r="2"/>
          </svg>
        </div>
        <div>
          <p class="font-display text-[12px] uppercase tracking-[0.18em] text-white/40">LinkedIn</p>
          <p class="mt-2 text-[1.02rem] text-white/70 transition-colors group-hover:text-accent-blue">
            Ruilin Xie
          </p>
        </div>
      </a>

    </div>

  </main>
</SiteLayout>
