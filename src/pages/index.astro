---
import SiteLayout from '../layouts/SiteLayout.astro';
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
---

<SiteLayout
  title="Peter Xie — Gameplay / System Engineer"
  description="Gameplay and systems engineer specialising in grid systems, modular game architecture, deterministic simulations, and rhythm game judgement mechanics — built in UE5 and Unity."
>
  <!-- Hero -->
  <section class="relative flex min-h-[92svh] flex-col items-center justify-center overflow-hidden px-6 py-24 text-center">
    <!-- Background radial glow -->
    <div
      class="pointer-events-none absolute inset-0 bg-[radial-gradient(ellipse_70%_50%_at_50%_40%,rgba(74,158,255,0.07),transparent_70%)]"
      aria-hidden="true"
    ></div>

    <!-- Subtle grid pattern -->
    <div
      class="pointer-events-none absolute inset-0 opacity-[0.025]"
      style="background-image: linear-gradient(rgba(255,255,255,0.5) 1px, transparent 1px), linear-gradient(90deg, rgba(255,255,255,0.5) 1px, transparent 1px); background-size: 60px 60px;"
      aria-hidden="true"
    ></div>

    <!-- Avatar / Initials circle -->
    <div
      class="relative z-10 mb-8 flex h-28 w-28 items-center justify-center rounded-full border border-white/10 bg-white/[0.04] ring-1 ring-accent-blue/20 shadow-[0_0_48px_rgba(74,158,255,0.08)]"
    >
      <span class="font-display text-3xl font-bold tracking-wider text-white/70" aria-label="Peter Xie">PX</span>
    </div>

    <!-- Name -->
    <h1 class="relative z-10 font-display text-[2.5rem] font-bold leading-tight tracking-tight text-white sm:text-5xl lg:text-6xl">
      Peter <span class="text-white/40">(Ruilin)</span> Xie
    </h1>

    <!-- Alias -->
    <p class="relative z-10 mt-2 font-body text-[0.82rem] tracking-[0.12em] text-white/28">aka Rin Misaka</p>

    <!-- Role label -->
    <p class="relative z-10 mt-5 font-display text-sm uppercase tracking-[0.26em] text-accent-blue">
      Gameplay&nbsp;/&nbsp;Systems&nbsp;Engineer
    </p>

    <!-- Bio -->
    <p class="relative z-10 mt-8 max-w-[50ch] text-[1.1rem] leading-[1.9] text-white/58">
      Every game is a small universe with its own constants. I derive those constants —
      the pull between things, the melody of every orbit, how time remembers itself.
      The system is Unreal. The resonance rests in Unity.
    </p>

    <!-- CTA -->
    <a
      href={`${base}/projects/`}
      class="relative z-10 mt-10 inline-flex min-h-[48px] items-center justify-center bg-accent-blue px-10 font-display text-[12px] uppercase tracking-[0.22em] text-white transition-all duration-300 hover:bg-white hover:text-page-bg"
    >
      View Projects
    </a>

    <!-- Scroll hint line -->
    <div
      class="relative z-10 mt-16 h-10 w-px bg-[linear-gradient(to_bottom,rgba(74,158,255,0.4),transparent)]"
      aria-hidden="true"
    ></div>
  </section>
</SiteLayout>
